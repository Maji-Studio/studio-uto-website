---
import { Image } from "astro:assets";

import type { Impression } from "@/lib/impressionen";

interface Props {
  entity: Impression;
}

const { entity } = Astro.props;

// Used when an image carries no explicit alt text.
const fallbackAlt = `Arbeit von ${entity.name}${
  entity.client ? ` für ${entity.client}` : ""
}.`;
---

<article class="entity">
  <header class="entity__meta">
    <h2 class="entity__name">{entity.name}</h2>
    {entity.client && <p class="entity__client">for {entity.client}</p>}
  </header>

  <ul class="entity__grid" role="list">
    {
      entity.images.map((image) => (
        <li class="entity__cell">
          <Image
            class="entity__image"
            src={image.src}
            alt={image.alt ?? fallbackAlt}
            widths={[240, 360, 480]}
            sizes="(max-width: 720px) 30vw, 18vw"
            loading="lazy"
          />
        </li>
      ))
    }
  </ul>
</article>

<style>
  /*
   * Two equal halves with an 8px gutter: collaborator meta (with its top
   * hairline) on the left, image grid on the right. The hairline runs the full
   * left column and the 8px column gap separates it from the gallery. The images
   * themselves sit flush, with no gap between them.
   */
  .entity {
    --impression-gap: 8px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--impression-gap);
    align-items: start;
  }

  .entity__meta {
    border-top: 1px solid var(--color-ink);
    padding-top: 10px;
  }

  .entity__name,
  .entity__client {
    margin: 0;
    font-size: clamp(1.05rem, 1.6vw, 1.4rem);
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: 0.005em;
  }

  .entity__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .entity__cell {
    margin: 0;
    /* Let the cell shrink below the image's intrinsic width so the 1fr tracks
       stay equal and the column gap is never eaten by grid blowout. */
    min-width: 0;
  }

  .entity__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  @media (max-width: 720px) {
    .entity {
      grid-template-columns: 1fr;
      row-gap: 12px;
    }
  }
</style>
