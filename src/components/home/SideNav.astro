---
import { sectionNav } from "@/lib/site";
---

<nav class="side-nav" aria-label="Studio-Informationen">
  {sectionNav.map((item) => <a class="chip" href={item.href}>{item.label}</a>)}
</nav>

<style>
  /* Fixed so it stays put once page content scrolls (Phase 2). */
  .side-nav {
    position: fixed;
    left: var(--page-pad);
    bottom: var(--page-pad);
    z-index: 40;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    max-width: calc(100vw - 2 * var(--page-pad));
  }
</style>
