---
import { sectionNav } from "@/lib/site";
---

{/*
 * In-page section navigation. Lives in normal flow directly below the gallery
 * hero and rides up to `position: sticky; top: 0` once the studio content
 * scrolls under it — chips only, no field/bar behind them, so content scrolls
 * freely in the gaps. A scroll-spy marks the section currently under the chips
 * with `.chip--active` — the same light-grey "current" treatment the header
 * uses for the live page.
 */}
<nav class="section-nav" aria-label="Studio-Informationen" data-section-nav>
  {
    sectionNav.map((item) => (
      <a class="chip" href={item.href} data-label={item.label}>
        {item.label}
      </a>
    ))
  }
</nav>

<script>
  const nav = document.querySelector<HTMLElement>("[data-section-nav]");

  if (nav) {
    const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>("a.chip"));

    // Map each section id → its chip, and collect the sections to observe.
    const byId = new Map<string, HTMLAnchorElement>();
    const sections: HTMLElement[] = [];
    for (const link of links) {
      const id = link.getAttribute("href")?.slice(1);
      if (!id) continue;
      const section = document.getElementById(id);
      if (!section) continue;
      byId.set(id, link);
      sections.push(section);
    }

    function setActive(id: string | null) {
      for (const [linkId, link] of byId) {
        const on = linkId === id;
        link.classList.toggle("chip--active", on);
        if (on) link.setAttribute("aria-current", "true");
        else link.removeAttribute("aria-current");
      }
    }

    // Scroll-spy: the section whose top sits just under the pinned chips wins.
    // The asymmetric rootMargin defines a thin "active line" near the top of
    // the viewport; whichever section last crossed it is active.
    const spy = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) setActive(entry.target.id);
        }
      },
      { rootMargin: "-18% 0px -78% 0px", threshold: 0 },
    );
    for (const section of sections) spy.observe(section);
  }
</script>

<style>
  /* Chips only — no field or shadow behind them; content scrolls in the gaps. */
  .section-nav {
    position: sticky;
    top: clamp(8px, 1.4vh, 12px);
    z-index: 30;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: clamp(36px, 8vh, 88px);
  }
</style>
