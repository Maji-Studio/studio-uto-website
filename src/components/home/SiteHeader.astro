---
import { isRouteActive } from "@/lib/routes";
import { primaryNav, site, socials } from "@/lib/site";

const path = Astro.url.pathname;

// A nav item is active when its real route matches the current path. Items still
// pointing at placeholder targets ("#") never match — except Studio, which stands
// in for the homepage until its destination lands.
function isNavActive(href: string, index: number) {
  if (href.startsWith("/")) return isRouteActive(path, href);
  return path === "/" && index === 0;
}

// Build-time German date; refreshed client-side so it always shows "today".
function formatGermanDate(date: Date): string {
  const weekday = new Intl.DateTimeFormat("de-CH", { weekday: "long" }).format(
    date,
  );
  const month = new Intl.DateTimeFormat("de-CH", { month: "long" }).format(
    date,
  );
  return `${weekday} ${date.getDate()}. ${month} ${date.getFullYear()}`;
}

const today = formatGermanDate(new Date());
---

<header class="site-header">
  <div class="site-header__group site-header__meta">
    <a class="chip" href="/" aria-label={`${site.name} — Startseite`}>
      STUDIO UTO
    </a>
    <time class="chip" id="today" datetime={new Date().toISOString().slice(0, 10)}>
      {today}
    </time>
  </div>

  <nav class="site-header__group site-header__nav" aria-label="Hauptnavigation">
    {
      primaryNav.map((item, i) => (
        <a
          class:list={["chip", { "chip--active": isNavActive(item.href, i) }]}
          href={item.href}
          aria-current={isNavActive(item.href, i) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>

  <div class="site-header__group site-header__socials">
    {socials.map((item) => <a class="chip" href={item.href}>{item.label}</a>)}
  </div>
</header>

<script>
  // Keep the date current regardless of when the page was built / cached.
  const el = document.getElementById("today");
  if (el) {
    const now = new Date();
    const weekday = new Intl.DateTimeFormat("de-CH", {
      weekday: "long",
    }).format(now);
    const month = new Intl.DateTimeFormat("de-CH", { month: "long" }).format(
      now,
    );
    el.textContent = `${weekday} ${now.getDate()}. ${month} ${now.getFullYear()}`;
    el.setAttribute("datetime", now.toISOString().slice(0, 10));
  }
</script>

<style>
  /*
   * Three equal-width tracks (1fr | auto | 1fr) so the centre nav is centred on
   * the page, not on the gap between the meta and socials groups. A plain
   * flex `space-between` would offset the nav by half the width difference
   * between the (wide) left meta group and the (narrow) right socials group.
   */
  .site-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    gap: 16px 24px;
    margin-top: 10px;
  }

  .site-header__group {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .site-header__meta {
    justify-self: start;
  }

  /* Centre nav wraps after three items, matching the reference (3 + 2). */
  .site-header__nav {
    justify-self: center;
    max-width: 300px;
    justify-content: center;
  }

  .site-header__socials {
    justify-self: end;
    justify-content: flex-end;
  }

  @media (max-width: 720px) {
    .site-header {
      grid-template-columns: 1fr;
    }

    .site-header__meta,
    .site-header__nav,
    .site-header__socials {
      justify-self: stretch;
      max-width: none;
      justify-content: flex-start;
    }
  }
</style>
